import pyautogui
import time
import msvcrt

print("Welcome to Don't Sleep")
print("-------Started------")
print("I will prevent your system from sleeping by giving short and sweet tasks :P")
print("Press any key to exit.")
print("-------")
print("Developed with <3 by DS")

try:
    while True:
        if msvcrt.kbhit():
            print("Key pressed. Exiting...")
            break
        
        pyautogui.press('volumedown')
        time.sleep(30) 
        pyautogui.press('volumeup')
        time.sleep(30)

except KeyboardInterrupt:
    print("Interrupted. Exiting...")
finally:
    print("Don't Sleep stopped.")  

    